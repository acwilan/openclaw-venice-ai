{
  "name": "openclaw-venice-media",
  "version": "2.3.1",
  "description": "Venice.ai image and video generation for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.4.0",
      "minGatewayVersion": "2026.4.0"
    },
    "build": {
      "openclawVersion": "2026.4.20",
      "pluginSdkVersion": "2026.4.20"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test ./test/*.test.mjs",
    "dev": "tsc --watch",
    "refresh-model-catalogs": "node ./scripts/refresh-model-catalogs.mjs",
    "check-model-catalogs": "node ./scripts/check-model-catalogs.mjs",
    "check-model-catalogs:drift": "node ./scripts/check-model-catalogs.mjs --check-drift"
  },
  "dependencies": {
    "openclaw": "^2026.4.20"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
