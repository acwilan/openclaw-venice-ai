{
  "id": "venice-media",
  "name": "Venice.ai Media Generation",
  "description": "Image and video generation using Venice.ai API",
  "version": "2.2.0",
  "author": "Andres Rovira",
  "authorUrl": "https://github.com/acwilan",
  "license": "MIT",
  "main": "dist/index.js",
  "runtime": "node",
  "entry": "index",
  "capabilities": [
    "image-generation",
    "video-generation"
  ],
  "requires": [
    "image-generation-core",
    "video-generation-core"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "baseUrl": {
        "type": "string",
        "description": "Venice.ai API base URL",
        "default": "https://api.venice.ai/api/v1"
      },
      "outputDir": {
        "type": "string",
        "description": "Directory for saving generated media",
        "default": "~/Downloads/venice-ai-output"
      },
      "defaultImageModel": {
        "type": "string",
        "description": "Default image model to use",
        "default": "flux-2-max"
      },
      "defaultVideoModel": {
        "type": "string",
        "description": "Default video model to use",
        "default": "ltx-2-fast-text-to-video"
      },
      "defaultImageSteps": {
        "type": "number",
        "description": "Number of inference steps for images (higher = better quality, slower)",
        "default": 30,
        "minimum": 1,
        "maximum": 50
      },
      "defaultImageCfgScale": {
        "type": "number",
        "description": "Guidance scale for images (higher = more adherence to prompt)",
        "default": 7.0,
        "minimum": 1.0,
        "maximum": 20.0
      },
      "defaultVideoDuration": {
        "type": "number",
        "description": "Default video duration in seconds",
        "default": 6,
        "minimum": 1,
        "maximum": 60
      },
      "defaultVideoFps": {
        "type": "number",
        "description": "Default video FPS",
        "default": 24,
        "minimum": 1,
        "maximum": 60
      },
      "defaultNegativePrompt": {
        "type": "string",
        "description": "Default negative prompt for image generation"
      },
      "defaultStylePreset": {
        "type": "string",
        "description": "Default style preset for image generation"
      },
      "defaultOutputFormat": {
        "type": "string",
        "description": "Default image output format",
        "enum": ["webp", "png", "jpeg"],
        "default": "webp"
      },
      "defaultVideoNegativePrompt": {
        "type": "string",
        "description": "Default negative prompt for video generation"
      },
      "hideWatermark": {
        "type": "boolean",
        "description": "Hide Venice.ai watermark on generated images",
        "default": false
      },
      "safeMode": {
        "type": "boolean",
        "description": "Enable content filtering/safe mode",
        "default": false
      }
    }
  }
}
